{
  "entities": {
    "userProfile": {
      "title": "User Profile",
      "description": "Stores user preferences and metadata",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "playlist": {
      "title": "Playlist",
      "description": "User created playlists",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "songIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name"]
    },
    "favorite": {
      "title": "Favorite",
      "description": "User favorite songs",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "songId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "songId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "userProfile",
      "description": "User profile documents"
    },
    "/users/{userId}/playlists/{playlistId}": {
      "schema": "playlist",
      "description": "User playlists"
    },
    "/users/{userId}/favorites/{favoriteId}": {
      "schema": "favorite",
      "description": "User favorite songs"
    }
  }
}
